{
  "name": "trackit-saas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev --config ./prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config ./prisma.config.ts",
    "db:push": "prisma db push --config ./prisma.config.ts",
    "db:studio": "prisma studio --config ./prisma.config.ts",
    "dev": "next dev --turbo",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate --config ./prisma.config.ts",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "inngest:dev": "npx inngest-cli@latest dev",
    "prepare": "husky install"
  },
